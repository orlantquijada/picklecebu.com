{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{js,jsx,ts,tsx,mjs}",
    "src/main.{js,jsx,ts,tsx,mjs}",
    "src/router.{ts,tsx}"
  ],
  "workspaces": {
    "packages": [
      "apps/*"
    ]
  },
  "ignorePatterns": [
    "apps/web/src/components/ui/**",
    "apps/mobile/**",
    ".claude/**"
  ],
  "rules": {}
}
